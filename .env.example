# =============================================================================
# Zeo++ Backend - Application Configuration
# =============================================================================
# 复制此文件为 .env 并按需修改。
# Copy this file to .env and adjust as needed.
#
# !! 重要 !!
# 下方只列出 Python 应用实际读取的变量。
# Docker Compose 专用变量（端口、容器名、资源限制等）已移至
# docker-compose.yml 的 environment 节，不要写入此文件，
# 否则 pydantic-settings 会因识别不了这些字段而报错。
#
# IMPORTANT: Only application-level variables are listed here.
# Docker-only variables (HOST_PORT, CONTAINER_NAME, CPU_LIMIT, etc.)
# belong in docker-compose.yml, NOT here. Adding them here will cause
# a pydantic ValidationError when running in stdio or HTTP mode.
# =============================================================================

# -----------------------------------------------------------------------------
# Zeo++ 配置
# -----------------------------------------------------------------------------

# Zeo++ 'network' 可执行文件路径。
# stdio 模式：留空，bootstrap 会自动安装到 ~/.local/bin/network
# Docker 模式：/usr/local/bin/network（容器内固定路径）
# ZEO_EXEC_PATH=

# 工作目录（临时文件与缓存）
# 默认: <项目根目录>/workspace
# ZEO_WORKSPACE=

# -----------------------------------------------------------------------------
# 缓存配置
# -----------------------------------------------------------------------------
ENABLE_CACHE=true
CACHE_MAX_AGE_HOURS=168

# -----------------------------------------------------------------------------
# 安全 / CORS
# -----------------------------------------------------------------------------
# CORS 允许来源，* 表示全部放行，生产环境建议指定具体域名
CORS_ORIGINS=*
# 每 IP 每分钟最大请求数
RATE_LIMIT_REQUESTS=100
# 最大上传文件大小 (MB)
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# MCP 配置
# -----------------------------------------------------------------------------

# HTTP 传输鉴权 Bearer Token（留空 = 不鉴权）
# stdio 模式无需填写
MCP_AUTH_TOKEN=

# Streamable HTTP 挂载路径（仅 HTTP 传输使用）
MCP_STREAMABLE_HTTP_PATH=/mcp

# structure_path 允许读取的根目录（逗号分隔）
# stdio 模式：bootstrap 自动设置为 $HOME,/tmp，通常无需手动填写
# Docker 模式：/app/workspace,/shared
# MCP_ALLOWED_PATH_ROOTS=

# MCP 文本字段最大返回字符数（超出截断）
MCP_MAX_RESULT_CHARS=12000

# -----------------------------------------------------------------------------
# 日志 / 性能
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
UVICORN_WORKERS=2
MAX_CONCURRENT_TASKS=4
