# =============================================================================
# Zeo++ API 部署配置文件 (Deployment Configuration)
# =============================================================================
# 复制此文件为 .env 并根据需要修改配置
# Copy this file to .env and modify as needed
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置 (Server Configuration)
# -----------------------------------------------------------------------------

# 外部访问端口 (External access port)
# 格式: HOST_PORT:CONTAINER_PORT 或仅 HOST_PORT (容器内部始终是8000)
HOST_PORT=9876

# MCP 服务外部端口 (MCP service external port)
MCP_HOST_PORT=9877

# 容器名称 (Container name)
CONTAINER_NAME=zeopp-api

# MCP 容器名称 (MCP container name)
MCP_CONTAINER_NAME=zeopp-mcp

# 镜像标签 (Image tag)
IMAGE_TAG=0.3.1

# -----------------------------------------------------------------------------
# 应用配置 (Application Configuration)
# -----------------------------------------------------------------------------

# Zeo++ 可执行文件路径 (通常不需要修改)
ZEO_EXEC_PATH=/usr/local/bin/network

# 是否启用缓存 (Enable caching)
ENABLE_CACHE=true

# 日志级别 (Log level): DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS 允许的来源 (Allowed origins)
# 使用 * 允许所有，或指定具体域名如: http://localhost:3000,https://example.com
CORS_ORIGINS=*

# 每分钟请求限制 (Rate limit per minute)
RATE_LIMIT_REQUESTS=100

# 最大上传文件大小 (MB)
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# MCP 配置 (MCP Configuration)
# -----------------------------------------------------------------------------

# MCP Bearer Token（为空表示不鉴权，生产环境强烈建议设置）
MCP_AUTH_TOKEN=

# MCP streamable HTTP 路径
MCP_STREAMABLE_HTTP_PATH=/mcp

# MCP 可读取的 structure_path 根目录（逗号分隔）
# 注意：只有这些目录下的文件能通过 structure_path 读取
MCP_ALLOWED_PATH_ROOTS=/app/workspace,/shared

# MCP 文本字段最大返回字符数（超出会截断）
MCP_MAX_RESULT_CHARS=12000

# -----------------------------------------------------------------------------
# 性能配置 (Performance Configuration)
# -----------------------------------------------------------------------------

# Uvicorn worker 进程数 (Number of Uvicorn worker processes)
# 多个 worker 可以让健康检查在长任务运行时正常响应
# 建议设置为 CPU 核心数
UVICORN_WORKERS=2

# 最大并发 Zeo++ 任务数 (Maximum concurrent Zeo++ tasks)
# 控制同时运行的 Zeo++ 计算任务数量（线程池大小）
MAX_CONCURRENT_TASKS=4

# -----------------------------------------------------------------------------
# 资源限制 (Resource Limits)
# -----------------------------------------------------------------------------

# CPU 限制 (CPU limit)
CPU_LIMIT=2

# 内存限制 (Memory limit)
MEMORY_LIMIT=2G

# CPU 预留 (CPU reservation)
CPU_RESERVATION=0.5

# 内存预留 (Memory reservation)
MEMORY_RESERVATION=512M
# -----------------------------------------------------------------------------
# 高级配置 (Advanced Configuration)
# -----------------------------------------------------------------------------

# 重启策略: no, always, on-failure, unless-stopped
RESTART_POLICY=unless-stopped

# 健康检查间隔 (秒) - 建议 >= 60s，因为 Zeo++ 计算可能很耗时
HEALTHCHECK_INTERVAL=60

# 健康检查超时 (秒) - 建议 >= 30s，长任务运行时 CPU 可能被占满
HEALTHCHECK_TIMEOUT=30

# 健康检查重试次数 - 建议 >= 5，避免长任务导致误判
HEALTHCHECK_RETRIES=5
