# =============================================================================
# Zeo++ API 部署配置文件 (Deployment Configuration)
# =============================================================================
# 复制此文件为 .env 并根据需要修改配置
# Copy this file to .env and modify as needed
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置 (Server Configuration)
# -----------------------------------------------------------------------------

# 外部访问端口 (External access port)
# 格式: HOST_PORT:CONTAINER_PORT 或仅 HOST_PORT (容器内部始终是8000)
HOST_PORT=9876

# 容器名称 (Container name)
CONTAINER_NAME=zeopp-api

# 镜像标签 (Image tag)
IMAGE_TAG=0.3.1

# -----------------------------------------------------------------------------
# 应用配置 (Application Configuration)
# -----------------------------------------------------------------------------

# Zeo++ 可执行文件路径 (通常不需要修改)
ZEO_EXEC_PATH=/usr/local/bin/network

# 是否启用缓存 (Enable caching)
ENABLE_CACHE=true

# 日志级别 (Log level): DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS 允许的来源 (Allowed origins)
# 使用 * 允许所有，或指定具体域名如: http://localhost:3000,https://example.com
CORS_ORIGINS=*

# 每分钟请求限制 (Rate limit per minute)
RATE_LIMIT_REQUESTS=100

# 最大上传文件大小 (MB)
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# 资源限制 (Resource Limits)
# -----------------------------------------------------------------------------

# CPU 限制 (CPU limit)
CPU_LIMIT=2

# 内存限制 (Memory limit)
MEMORY_LIMIT=2G

# CPU 预留 (CPU reservation)
CPU_RESERVATION=0.5

# 内存预留 (Memory reservation)
MEMORY_RESERVATION=512M

# -----------------------------------------------------------------------------
# 高级配置 (Advanced Configuration)
# -----------------------------------------------------------------------------

# 重启策略: no, always, on-failure, unless-stopped
RESTART_POLICY=unless-stopped

# 健康检查间隔 (秒)
HEALTHCHECK_INTERVAL=30

# 健康检查超时 (秒)
HEALTHCHECK_TIMEOUT=10

# 健康检查重试次数
HEALTHCHECK_RETRIES=3

# 日志文件最大大小
LOG_MAX_SIZE=10m

# 保留日志文件数量
LOG_MAX_FILES=3
