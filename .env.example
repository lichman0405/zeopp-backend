# =============================================================================
# Zeo++ Backend - Application Configuration
# =============================================================================
# Copy this file to .env and adjust as needed.
#
# IMPORTANT: Only application-level variables are listed here.
# Docker-only variables (HOST_PORT, CONTAINER_NAME, CPU_LIMIT, etc.)
# belong in docker-compose.yml, NOT here. Adding them here will cause
# a pydantic ValidationError when running in stdio or HTTP mode.
# =============================================================================

# -----------------------------------------------------------------------------
# Zeo++ Configuration
# -----------------------------------------------------------------------------

# Path to Zeo++ 'network' executable.
# stdio mode: leave empty, bootstrap will auto-install to ~/.local/bin/network
# Docker mode: /usr/local/bin/network (fixed path inside container)
# ZEO_EXEC_PATH=

# Working directory (temporary files and cache)
# Default: <project_root>/workspace
# ZEO_WORKSPACE=

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------
ENABLE_CACHE=true
CACHE_MAX_AGE_HOURS=168

# -----------------------------------------------------------------------------
# Security / CORS
# -----------------------------------------------------------------------------
# CORS allowed origins, * means allow all, specify concrete domains in production
CORS_ORIGINS=*
# Maximum requests per IP per minute
RATE_LIMIT_REQUESTS=100
# Maximum file upload size (MB)
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# MCP Configuration
# -----------------------------------------------------------------------------

# HTTP transport auth Bearer Token (empty = no auth)
# stdio mode does not need this
MCP_AUTH_TOKEN=

# Streamable HTTP mount path (HTTP transport only)
MCP_STREAMABLE_HTTP_PATH=/mcp

# Allowed root directories for structure_path (comma-separated)
# stdio mode: bootstrap auto-sets to $HOME,/tmp, usually no manual config needed
# Docker mode: /app/workspace,/shared
# MCP_ALLOWED_PATH_ROOTS=

# Maximum characters returned in MCP text fields (truncates if exceeded)
MCP_MAX_RESULT_CHARS=12000

# -----------------------------------------------------------------------------
# Logging / Performance
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
UVICORN_WORKERS=2
MAX_CONCURRENT_TASKS=4
